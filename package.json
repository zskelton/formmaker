{
  "name": "formmaker_ai",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "check": "vinext check",
    "dev:desktop": "concurrently -k --success first \"npm run dev -- --port 3417 --strictPort\" \"wait-on http://localhost:3417 && cross-env VITE_DEV_SERVER_URL=http://localhost:3417 electron .\"",
    "start:desktop": "electron .",
    "build:desktop": "npm run build && electron-builder"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "next": "^15.0.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vinext": "^0.0.15"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-rsc": "^0.5.19",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^36.4.0",
    "electron-builder": "^24.13.3",
    "react-server-dom-webpack": "^19.2.4",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.skeltonnetworks.formmaker",
    "productName": "Formmaker",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "app/**/*",
      "dist/**/*",
      "electron/**/*",
      "next.config.mjs",
      "next-env.d.ts",
      "package.json",
      "tsconfig.json",
      "vite.config.ts"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
