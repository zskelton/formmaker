{
  "name": "formmaker",
  "version": "1.0.1",
  "description": "Formmaker desktop app",
  "author": "Skelton Networks",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "check": "vinext check",
    "dev:desktop": "concurrently -k --success first \"npm run dev -- --port 3417 --strict-port\" \"wait-on http://localhost:3417 && cross-env VITE_DEV_SERVER_URL=http://localhost:3417 electron .\"",
    "start:desktop": "electron .",
    "build:desktop": "npm run build && electron-builder",
    "build:portable": "npm run build && electron-builder --win portable",
    "build:nsis": "npm run build && electron-builder --win nsis",
    "test": "node --experimental-strip-types --test",
    "test:watch": "node --experimental-strip-types --test --watch"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.95",
    "jszip": "^3.10.1",
    "next": "^15.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vinext": "^0.0.15",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-rsc": "^0.5.19",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^36.4.0",
    "electron-builder": "^24.13.3",
    "react-server-dom-webpack": "^19.2.4",
    "typescript": "^5.9.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.skeltonnetworks.formmaker",
    "productName": "Formmaker",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "app/**/*",
      "dist/**/*",
      "electron/**/*",
      "next.config.mjs",
      "next-env.d.ts",
      "package.json",
      "tsconfig.json",
      "vite.config.ts"
    ],
    "win": {
      "icon": "app/icon.png",
      "target": "nsis"
    }
  }
}
